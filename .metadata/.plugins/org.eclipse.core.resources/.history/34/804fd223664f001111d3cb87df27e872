        JButton button =
                new JButton(text);

        button.setFocusPainted(false);

        button.setBorder(null);

        button.setBackground(
                Color.WHITE
        );

        button.setFont(
                new Font(
                        "Segoe UI",
                        Font.PLAIN,
                        18
                )
        );

        return button;
    }
