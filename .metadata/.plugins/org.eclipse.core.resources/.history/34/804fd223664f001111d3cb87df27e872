    // =========================
    // CREATE CARD
    // =========================
    private RoundedPanel createCard(
            String icon,
            String title,
            String desc
    ) {

        RoundedPanel panel =
                new RoundedPanel(
                        30,
                        Color.WHITE
                );

        panel.setLayout(null);

        JLabel lblIcon =
                new JLabel(
                        icon,
                        SwingConstants.CENTER
                );

        lblIcon.setFont(
                new Font(
                        "Segoe UI Emoji",
                        Font.PLAIN,
                        48
                )
        );

        lblIcon.setBounds(
                120,
                20,
                100,
                60
        );

        panel.add(lblIcon);

        JLabel lblTitle =
                new JLabel(
                        title,
                        SwingConstants.CENTER
                );

        lblTitle.setFont(
                new Font(
                        "Segoe UI",
                        Font.BOLD,
                        26
                )
        );

        lblTitle.setBounds(
                0,
                100,
                340,
                40
        );

        panel.add(lblTitle);

        JLabel lblDesc =
                new JLabel(
                        desc,
                        SwingConstants.CENTER
                );

        lblDesc.setForeground(
                Color.GRAY
        );

        lblDesc.setFont(
                new Font(
                        "Segoe UI",
                        Font.PLAIN,
                        16
                )
        );

        lblDesc.setBounds(
                0,
                150,
                340,
                30
        );

        panel.add(lblDesc);

        return panel;
    }

    // =========================
    // NAV BUTTON
