package hotel;

import javax.swing.*;
import java.awt.*;
import javax.swing.border.LineBorder;

public class LoginFrame extends JFrame {

    private JTextField txtUsername;
    private JPasswordField txtPassword;
    private JButton btnLogin;
    private TaiKhoanService tkService;

    public LoginFrame() {
        tkService = new TaiKhoanService();

        setTitle("Đăng nhập");
        // Tăng chiều cao để giống form dọc trong hình
        setSize(500, 700); 
        setLocationRelativeTo(null);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        // Sử dụng GridBagLayout để căn chỉnh tự do như hình vẽ
        JPanel panel = new JPanel();
        panel.setBackground(new Color(18, 18, 18)); // Nền đen
        panel.setLayout(new GridBagLayout());
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(15, 10, 15, 10);
        gbc.fill = GridBagConstraints.HORIZONTAL;

        // 1. Logo Oval (Dòng chữ *LOGO KHÁCH SẠN Ở ĐÂY)
        JLabel lblLogo = new JLabel("*LOGO KHÁCH SẠN Ở ĐÂY", SwingConstants.CENTER);
        lblLogo.setForeground(Color.WHITE);
        lblLogo.setPreferredSize(new Dimension(350, 120));
        lblLogo.setBorder(new LineBorder(Color.WHITE, 1, true)); // Viền bo góc
        gbc.gridx = 0;
        gbc.gridy = 0;
        gbc.gridwidth = 2;
        panel.add(lblLogo, gbc);

        // 2. Nút Đăng nhập lớn (Đóng vai trò tiêu đề khung)
        btnLogin = new JButton("Đăng nhập");
        btnLogin.setFont(new Font("Arial", Font.BOLD, 20));
        btnLogin.setForeground(Color.WHITE);
        btnLogin.setBackground(new Color(18, 18, 18));
        btnLogin.setFocusPainted(false);
        btnLogin.setBorder(new LineBorder(Color.WHITE, 1));
        btnLogin.setPreferredSize(new Dimension(300, 50));
        gbc.gridy = 1;
        panel.add(btnLogin, gbc);

        // 3. Nhãn "Tên đăng nhập" và ô nhập
        JLabel lblUser = new JLabel("Tên đăng nhập");
        lblUser.setForeground(Color.WHITE);
        gbc.gridy = 2;
        gbc.gridwidth = 1;
        panel.add(lblUser, gbc);

        txtUsername = new JTextField();
        txtUsername.setBackground(Color.BLACK);
        txtUsername.setForeground(Color.WHITE);
        txtUsername.setCaretColor(Color.WHITE);
        txtUsername.setBorder(new LineBorder(Color.GRAY, 1));
        txtUsername.setPreferredSize(new Dimension(250, 30));
        gbc.gridx = 1;
        panel.add(txtUsername, gbc);

        // 4. Nhãn "Mật khẩu" và ô nhập
        JLabel lblPass = new JLabel("Mật khẩu");
        lblPass.setForeground(Color.WHITE);
        gbc.gridx = 0;
        gbc.gridy = 3;
        panel.add(lblPass, gbc);

        txtPassword = new JPasswordField();
        txtPassword.setBackground(Color.BLACK);
        txtPassword.setForeground(Color.WHITE);
        txtPassword.setCaretColor(Color.WHITE);
        txtPassword.setBorder(new LineBorder(Color.GRAY, 1));
        txtPassword.setPreferredSize(new Dimension(250, 30));
        gbc.gridx = 1;
        panel.add(txtPassword, gbc);

        // 5. Nút Qua đăng ký (Dạng chữ gạch chân như hình)
        JButton btnRegister = new JButton("Đăng ký");
        btnRegister.setContentAreaFilled(false);
        btnRegister.setForeground(Color.WHITE);
        btnRegister.setFocusPainted(false);
        btnRegister.setBorder(BorderFactory.createMatteBorder(0, 0, 1, 0, Color.WHITE));
        gbc.gridx = 0;
        gbc.gridy = 4;
        gbc.gridwidth = 1;
        panel.add(btnRegister, gbc);

        // 6. Nút Quên mật khẩu (Bổ sung cho giống hình)
        JButton btnForgot = new JButton("Quên mật khẩu?");
        btnForgot.setContentAreaFilled(false);
        btnForgot.setForeground(Color.WHITE);
        btnForgot.setFocusPainted(false);
        btnForgot.setBorder(BorderFactory.createMatteBorder(0, 0, 1, 0, Color.WHITE));
        gbc.gridx = 1;
        panel.add(btnForgot, gbc);

        add(panel);

        // --- GIỮ NGUYÊN LOGIC XỬ LÝ CỦA BẠN ---
        
        // Sự kiện đăng nhập
        btnLogin.addActionListener(e -> {
            String username = txtUsername.getText();
            String password = new String(txtPassword.getPassword());

            // Lưu ý: Đổi lại tên hàm cho đúng với Service của bạn 
            // (Ví dụ trước đó báo lỗi dangNhap vs kiemTraDangNhap)
            TaiKhoan tk = tkService.dangNhap(username, password);

            if (tk != null) {
                JOptionPane.showMessageDialog(this, "Xin chào " + tk.getTenDangNhap());
            } else {
                JOptionPane.showMessageDialog(this, "Sai tài khoản hoặc mật khẩu");
            }
        });

        // Sự kiện qua đăng ký
        btnRegister.addActionListener(e -> {
            new RegisterFrame().setVisible(true);
            dispose();
        });
    }
}