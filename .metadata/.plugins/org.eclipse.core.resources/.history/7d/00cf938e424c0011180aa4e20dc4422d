package hotel;

import java.sql.Connection;
import java.sql.PreparedStatement;

public class DatPhongDAO {

    public boolean datPhong(
            DatPhong dp
    ) {

        String sql =
                "INSERT INTO datphong(tenDangNhap, maPhong, ngayNhan, ngayTra) VALUES (?, ?, ?, ?)";

        try (

                Connection conn =
                        DBConnection.getConnection();

                PreparedStatement stmt =
                        conn.prepareStatement(sql)

        ) {

            stmt.setString(
                    1,
                    dp.getTenDangNhap()
            );

            stmt.setString(
                    2,
                    dp.getMaPhong()
            );

            stmt.setDate(
                    3,
                    dp.getNgayNhan()
            );

            stmt.setDate(
                    4,
                    dp.getNgayTra()
            );

            stmt.executeUpdate();

            return true;

        } catch (Exception e) {

            e.printStackTrace();
        }

        return false;
    }
}