package hotel;

import javax.swing.*;
import javax.swing.border.EmptyBorder;
import java.awt.*;

public class HomeFrame extends JFrame {

    private TaiKhoan taiKhoan;

    public HomeFrame(TaiKhoan taiKhoan) {

        this.taiKhoan = taiKhoan;

        setTitle("Hotel Management");

        setSize(900, 600);

        setLocationRelativeTo(null);

        setDefaultCloseOperation(
                JFrame.EXIT_ON_CLOSE
        );

        setLayout(new BorderLayout());

        // =========================
        // MAIN PANEL
        // =========================
        JPanel mainPanel = new JPanel();

        mainPanel.setBackground(
                new Color(245, 245, 245)
        );

        mainPanel.setBorder(
                new EmptyBorder(
                        30,
                        30,
                        30,
                        30
                )
        );

        mainPanel.setLayout(null);

        // =========================
        // HELLO USER
        // =========================
        JLabel lblHello =
                new JLabel(
                        "Xin chào, "
                        + taiKhoan.getTenDangNhap()
                );

        lblHello.setFont(
                new Font(
                        "Segoe UI",
                        Font.BOLD,
                        28
                )
        );

        lblHello.setBounds(
                20,
                20,
                500,
                40
        );

        mainPanel.add(lblHello);

        // =========================
        // SEARCH BAR
        // =========================
        JTextField txtSearch =
                new JTextField();

        txtSearch.setFont(
                new Font(
                        "Segoe UI",
                        Font.PLAIN,
                        16
                )
        );

        txtSearch.setBounds(
                20,
                90,
                820,
                45
        );

        txtSearch.setText(
                "Tìm kiếm..."
        );

        mainPanel.add(txtSearch);

        // =========================
        // FEATURE PANEL
        // =========================
        JPanel featurePanel =
                new JPanel();

        featurePanel.setBackground(
                Color.WHITE
        );

        featurePanel.setBounds(
                20,
                180,
                820,
                220
        );

        featurePanel.setLayout(
                new GridLayout(
                        1,
                        3,
                        20,
                        20
                )
        );

        // =========================
        // ĐẶT PHÒNG
        // =========================
        JButton btnDatPhong =
                new JButton(
                        "Đặt phòng"
                );

        btnDatPhong.setFont(
                new Font(
                        "Segoe UI",
                        Font.BOLD,
                        20
                )
        );

        // =========================
        // DỊCH VỤ
        // =========================
        JButton btnDichVu =
                new JButton(
                        "Dịch vụ khác"
                );

        btnDichVu.setFont(
                new Font(
                        "Segoe UI",
                        Font.BOLD,
                        20
                )
        );

        // =========================
        // TRA CỨU
        // =========================
        JButton btnTraCuu =
                new JButton(
                        "Tra cứu"
                );

        btnTraCuu.setFont(
                new Font(
                        "Segoe UI",
                        Font.BOLD,
                        20
                )
        );

        featurePanel.add(btnDatPhong);

        featurePanel.add(btnDichVu);

        featurePanel.add(btnTraCuu);

        mainPanel.add(featurePanel);

        // =========================
        // BOTTOM NAVIGATION
        // =========================
        JPanel navPanel =
                new JPanel();

        navPanel.setBackground(
                Color.WHITE
        );

        navPanel.setPreferredSize(
                new Dimension(900, 70)
        );

        navPanel.setLayout(
                new GridLayout(
                        1,
                        3
                )
        );

        JButton btnHome =
                new JButton(
                        "Trang chủ"
                );

        JButton btnPhong =
                new JButton(
                        "Phòng"
                );

        JButton btnProfile =
                new JButton(
                        "Thông tin cá nhân"
                );

        btnHome.setFont(
                new Font(
                        "Segoe UI",
                        Font.PLAIN,
                        16
                )
        );

        btnPhong.setFont(
                new Font(
                        "Segoe UI",
                        Font.PLAIN,
                        16
                )
        );

        btnProfile.setFont(
                new Font(
                        "Segoe UI",
                        Font.PLAIN,
                        16
                )
        );

        navPanel.add(btnHome);

        navPanel.add(btnPhong);

        navPanel.add(btnProfile);

        // =========================
        // ADD COMPONENT
        // =========================
        add(mainPanel, BorderLayout.CENTER);

        add(navPanel, BorderLayout.SOUTH);
    }
}