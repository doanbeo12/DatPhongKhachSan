                    );

            TaiKhoan tk =
                    tkService.dangNhap(
                            username,
                            password
                    );

            if (tk != null) {

                JOptionPane.showMessageDialog(
                        this,
                        "Đăng nhập thành công"
                );

            } else {

                JOptionPane.showMessageDialog(
                        this,
                        "Sai tài khoản hoặc mật khẩu"
                );
            }
        });

        // =========================
        // REGISTER EVENT
        // =========================
        btnRegister.addActionListener(e -> {

            new RegisterFrame()
                    .setVisible(true);

            dispose();
        });

