    // =========================
    // CREATE CARD
    // =========================
    private JPanel createCard(
            String icon,
            String title,
            String desc
    ) {

        JPanel panel =
                new JPanel();

        panel.setLayout(null);

        panel.setBackground(
                Color.WHITE
        );

        panel.setBorder(
                BorderFactory.createLineBorder(
                        new Color(240,240,240)
                )
        );

        JLabel lblIcon =
                new JLabel(
                        icon,
                        SwingConstants.CENTER
                );

        lblIcon.setFont(
                new Font(
                        "Segoe UI Emoji",
                        Font.PLAIN,
                        38
                )
        );

        lblIcon.setBounds(
                20,
                20,
                80,
                60
        );

        panel.add(lblIcon);

        JLabel lblTitle =
                new JLabel(
                        title,
                        SwingConstants.CENTER
                );

        lblTitle.setFont(
                new Font(
                        "Segoe UI",
                        Font.BOLD,
                        18
                )
        );

        lblTitle.setBounds(
                0,
                100,
                110,
                30
        );

        panel.add(lblTitle);

        JLabel lblDesc =
                new JLabel(
                        "<html><center>"
                        + desc
                        + "</center></html>",
                        SwingConstants.CENTER
                );

        lblDesc.setBounds(
                5,
                140,
                100,
                50
        );

        lblDesc.setForeground(
                Color.GRAY
        );

        panel.add(lblDesc);

        return panel;
    }

    // =========================
    // NAV BUTTON
    // =========================
    private JButton createNavButton(
            String text
    ) {

        JButton button =
                new JButton(
                        "<html><center>"
                        + text.replace("\n", "<br>")
                        + "</center></html>"
                );

        button.setFocusPainted(false);

        button.setBackground(
                Color.WHITE
        );

        button.setBorder(null);

        button.setFont(
                new Font(
                        "Segoe UI",
                        Font.PLAIN,
                        15
                )
        );

        return button;
    }
